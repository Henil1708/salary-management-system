# Server
NODE_ENV=development
PORT=5000

# Database (Supabase PostgreSQL)
# DATABASE_URL — "Transaction"/"Session" pooler (port 6543), used by the app at runtime.
# DIRECT_URL   — direct connection (port 5432), required by Prisma migrations.
# Both from: Supabase Dashboard > Project Settings > Database > Connection string
DATABASE_URL="postgresql://postgres.uqcqamyrdbqxupeqrunh:[password]@aws-0-[region].pooler.supabase.com:6543/postgres?pgbouncer=true"
DIRECT_URL="postgresql://postgres.uqcqamyrdbqxupeqrunh:[password]@aws-0-[region].pooler.supabase.com:5432/postgres"

# CORS — the client app's origin
CORS_ORIGIN=http://localhost:5173

# Logging
LOG_LEVEL=info

# JWT — two independent secrets (access vs refresh), 32+ chars each.
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_ACCESS_SECRET=
JWT_REFRESH_SECRET=
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d
RESET_TOKEN_TTL_MINUTES=30
